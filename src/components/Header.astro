---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
    <a href={`/${lang}/`} class="text-base font-semibold text-[--color-notion-text]">
      {t('nav.home')}
    </a>
    <div class="flex items-center gap-5">
      <a href={`/${lang}/docs/`} class="text-sm text-[--color-notion-secondary] hover:text-[--color-notion-text] transition-colors">
        {t('nav.docs')}
      </a>
      <LangSwitch lang={lang} />
      <a
        href="#pricing"
        class="rounded-full bg-black px-5 py-1.5 text-sm font-medium text-white hover:bg-gray-800 transition-colors"
      >
        {t('nav.getStarted')}
      </a>
    </div>
  </nav>
</header>
