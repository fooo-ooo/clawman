---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header class="sticky top-0 z-50 border-b border-[--color-notion-border] bg-white/95 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-3">
    <a href={`/${lang}/`} class="text-base font-semibold text-[--color-notion-text]">
      {t('nav.home')}
    </a>
    <div class="flex items-center gap-5">
      <a href={`/${lang}/docs/`} class="text-sm text-[--color-notion-secondary] hover:text-[--color-notion-text] transition-colors">
        {t('nav.docs')}
      </a>
      <LangSwitch lang={lang} />
      <a
        href="#pricing"
        class="rounded-lg bg-[--color-notion-text] px-4 py-1.5 text-sm font-medium text-white hover:opacity-90 transition-opacity"
      >
        {t('nav.getStarted')}
      </a>
    </div>
  </nav>
</header>
