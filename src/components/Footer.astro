---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-[--color-notion-light-gray] px-6 py-10">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col items-center gap-4 text-center">
      <div class="flex gap-6 text-sm text-[--color-notion-secondary]">
        <a href="https://x.com/agent_fooo_ooo" target="_blank" rel="noopener" class="hover:text-[--color-notion-text] transition-colors">
          Twitter
        </a>
        <a href="https://github.com/fooo-ooo" target="_blank" rel="noopener" class="hover:text-[--color-notion-text] transition-colors">
          GitHub
        </a>
        <a href={`/${lang}/docs/`} class="hover:text-[--color-notion-text] transition-colors">
          {t('nav.docs')}
        </a>
      </div>
      <p class="text-xs text-[--color-notion-secondary]">{t('footer.copy')}</p>
    </div>
  </div>
</footer>
