---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Article {
  title: string;
  href: string;
}

interface Props {
  articles: Article[];
  lang: Lang;
}

const { articles, lang } = Astro.props;
const t = useTranslations(lang);
---

{articles.length > 0 && (
  <section class="mt-12 border-t border-[--color-notion-border] pt-8">
    <h3 class="mb-4 text-lg font-semibold text-[--color-notion-text]">{t('docs.related')}</h3>
    <ul class="grid gap-3 sm:grid-cols-2">
      {articles.map((article) => (
        <li>
          <a
            href={article.href}
            class="block rounded-lg border border-[--color-notion-border] p-4 hover:bg-[--color-notion-light] transition-colors"
          >
            <span class="text-sm font-medium text-[--color-notion-text]">{article.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
