---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="technology" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-5xl">
    <div class="rounded-2xl bg-[--color-notion-light-gray] p-10 sm:p-14 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-[--color-notion-secondary]">{t('tech.label')}</p>
      <h2 class="mt-4 text-3xl font-bold text-[--color-notion-text] sm:text-4xl">{t('tech.title')}</h2>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-[--color-notion-secondary]">{t('tech.desc')}</p>
      <a
        href={`/${lang}/docs/`}
        class="mt-8 inline-block rounded-full bg-black px-7 py-3 text-base font-medium text-white hover:bg-gray-800 transition-colors"
      >
        {t('tech.cta')} &rarr;
      </a>
    </div>
  </div>
</section>
