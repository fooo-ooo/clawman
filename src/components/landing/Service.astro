---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const cards = [
  { title: t('service.card1.title'), desc: t('service.card1.desc'), bg: 'bg-[--color-notion-teal]' },
  { title: t('service.card2.title'), desc: t('service.card2.desc'), bg: 'bg-[--color-notion-blue]' },
  { title: t('service.card3.title'), desc: t('service.card3.desc'), bg: 'bg-[--color-notion-orange]' },
  { title: t('service.card4.title'), desc: t('service.card4.desc'), bg: 'bg-[--color-notion-yellow]' },
  { title: t('service.card5.title'), desc: t('service.card5.desc'), bg: 'bg-[--color-notion-purple]' },
  { title: t('service.card6.title'), desc: t('service.card6.desc'), bg: 'bg-[--color-notion-red]' },
];
---

<section id="service" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-5xl">
    <p class="text-sm font-medium uppercase tracking-widest text-[--color-notion-secondary]">{t('service.label')}</p>
    <h2 class="mt-4 max-w-2xl text-3xl font-bold text-[--color-notion-text] sm:text-4xl">{t('service.title')}</h2>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <div class={`rounded-2xl ${card.bg} p-7`}>
          <h3 class="text-lg font-semibold text-[--color-notion-text]">{card.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-[--color-notion-text]/70">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
