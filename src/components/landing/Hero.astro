---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-[--color-notion-text] sm:text-5xl lg:text-6xl">
      {t('hero.title')}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-[--color-notion-secondary] sm:text-xl leading-relaxed">
      {t('hero.subtitle')}
    </p>
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="#pricing"
        class="rounded-lg bg-[--color-notion-text] px-8 py-3 text-base font-medium text-white hover:opacity-90 transition-opacity"
      >
        {t('hero.cta')}
      </a>
      <a
        href={`/${lang}/docs/`}
        class="rounded-lg border border-[--color-notion-border] px-8 py-3 text-base font-medium text-[--color-notion-text] hover:bg-[--color-notion-hover] transition-colors"
      >
        {t('tech.cta')}
      </a>
    </div>
    <p class="mt-4 text-sm text-[--color-notion-secondary]">{t('hero.note')}</p>
  </div>
</section>
