---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-gradient-to-br from-ocean-900 to-lobster-900 py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">{t('cta.title')}</h2>
    <a
      href="https://x.com/messages/compose?recipient_id=1234567890"
      target="_blank"
      rel="noopener"
      class="mt-8 inline-block rounded-xl bg-lobster-600 px-10 py-4 text-lg font-semibold text-white shadow-lg shadow-lobster-600/25 hover:bg-lobster-500 transition-all"
    >
      {t('cta.button')}
    </a>
    <p class="mt-6 text-gray-400">{t('cta.contact')}</p>
    <div class="mt-4 flex justify-center gap-6 text-sm text-gray-300">
      <a href="https://x.com/agent_fooo_ooo" target="_blank" rel="noopener" class="hover:text-white transition-colors">
        Twitter: @agent_fooo_ooo
      </a>
    </div>
  </div>
</section>
