---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const cards = [
  { title: t('problem.card1.title'), desc: t('problem.card1.desc') },
  { title: t('problem.card2.title'), desc: t('problem.card2.desc') },
  { title: t('problem.card3.title'), desc: t('problem.card3.desc') },
];
---

<section id="problem" class="border-t border-[--color-notion-border] py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-6">
    <p class="text-sm font-medium uppercase tracking-wider text-[--color-notion-secondary]">{t('problem.label')}</p>
    <h2 class="mt-3 text-2xl font-bold text-[--color-notion-text] sm:text-3xl">{t('problem.title')}</h2>
    <div class="mt-10 space-y-6">
      {cards.map((card) => (
        <div class="rounded-lg border border-[--color-notion-border] p-6">
          <h3 class="font-semibold text-[--color-notion-text]">{card.title}</h3>
          <p class="mt-2 text-[--color-notion-secondary] leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
    <p class="mt-8 text-lg font-semibold text-[--color-notion-text]">{t('problem.punch')}</p>
  </div>
</section>
