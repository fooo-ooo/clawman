---
import { languages, type Lang } from '../i18n/ui';
import { getAlternateLang, getLocalizedPath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const altLang = getAlternateLang(lang);
const altPath = getLocalizedPath(Astro.url.pathname, altLang);
---

<div class="flex items-center gap-1 text-sm">
  <span class={lang === 'en' ? 'font-semibold text-lobster-600' : 'text-gray-400'}>EN</span>
  <span class="text-gray-300">/</span>
  <a
    href={altPath}
    class={lang === 'zh' ? 'font-semibold text-lobster-600' : 'text-gray-400 hover:text-lobster-600 transition-colors'}
  >
    中
  </a>
</div>
