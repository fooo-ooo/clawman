---
import { languages, type Lang } from '../i18n/ui';
import { getAlternateLang, getLocalizedPath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const altLang = getAlternateLang(lang);
const altPath = getLocalizedPath(Astro.url.pathname, altLang);
---

<div class="flex items-center gap-1 text-sm text-[--color-notion-secondary]">
  <span class={lang === 'en' ? 'font-medium text-[--color-notion-text]' : ''}>EN</span>
  <span>/</span>
  <a
    href={altPath}
    class={lang === 'zh' ? 'font-medium text-[--color-notion-text]' : 'hover:text-[--color-notion-text] transition-colors'}
  >
    中
  </a>
</div>
