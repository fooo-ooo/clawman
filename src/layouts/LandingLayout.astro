---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  jsonLd?: Record<string, any>;
}

const { title, description, lang, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang} jsonLd={jsonLd}>
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
</BaseLayout>
