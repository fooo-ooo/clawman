---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist." lang="en">
  <div class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <h1 class="text-6xl font-bold text-[--color-notion-text]">404</h1>
    <p class="mt-4 text-lg text-[--color-notion-secondary]">Page not found</p>
    <div class="mt-8 flex gap-3">
      <a href="/en/" class="rounded-full bg-black px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-800 transition-colors">
        English Home
      </a>
      <a href="/zh/" class="rounded-full bg-[--color-notion-light-gray] px-6 py-2.5 text-sm font-medium text-[--color-notion-text] hover:bg-[--color-notion-border] transition-colors">
        中文首页
      </a>
    </div>
  </div>
</BaseLayout>
