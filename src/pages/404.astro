---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist." lang="en">
  <div class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <h1 class="text-6xl font-extrabold text-lobster-600">404</h1>
    <p class="mt-4 text-xl text-gray-600">Page not found</p>
    <div class="mt-8 flex gap-4">
      <a href="/en/" class="rounded-lg bg-lobster-600 px-6 py-2.5 font-semibold text-white hover:bg-lobster-700 transition-colors">
        English Home
      </a>
      <a href="/zh/" class="rounded-lg border border-gray-200 px-6 py-2.5 font-semibold text-ocean-900 hover:bg-gray-50 transition-colors">
        中文首页
      </a>
    </div>
  </div>
</BaseLayout>
