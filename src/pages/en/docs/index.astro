---
import { getCollection } from 'astro:content';
import LandingLayout from '../../../layouts/LandingLayout.astro';

const lang = 'en';
const allDocs = await getCollection('docs');
const enDocs = allDocs.filter((doc) => doc.data.lang === 'en');

// Group by category
const categories = new Map<string, typeof enDocs>();
for (const doc of enDocs) {
  const cat = doc.data.category;
  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(doc);
}
// Sort each category by order
for (const [, docs] of categories) {
  docs.sort((a, b) => a.data.order - b.data.order);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'OpenClaw Knowledge Base',
  description: 'Comprehensive documentation and guides for OpenClaw agent framework',
  url: 'https://clawman.fooo.ooo/en/docs/',
};
---

<LandingLayout
  title="OpenClaw Knowledge Base"
  description="Comprehensive documentation, guides, and tutorials for the OpenClaw agent framework. Learn to build, deploy, and manage AI agents."
  lang={lang}
  jsonLd={jsonLd}
>
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="text-4xl font-extrabold text-ocean-900">OpenClaw Knowledge Base</h1>
      <p class="mt-4 text-lg text-gray-600">
        Everything you need to understand, deploy, and master OpenClaw — the open-source agent framework.
      </p>

      {categories.size > 0 ? (
        <div class="mt-12 space-y-12">
          {[...categories.entries()].map(([category, docs]) => (
            <div>
              <h2 class="text-2xl font-bold text-ocean-900">{category}</h2>
              <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                {docs.map((doc) => (
                  <li>
                    <a
                      href={`/en/docs/${doc.id.replace('en/', '')}`}
                      class="block rounded-xl border border-gray-100 p-5 hover:border-lobster-200 hover:shadow-md transition-all"
                    >
                      <h3 class="font-semibold text-ocean-900">{doc.data.title}</h3>
                      <p class="mt-1 text-sm text-gray-500 line-clamp-2">{doc.data.description}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-2xl border border-gray-100 bg-gray-50 p-12 text-center">
          <p class="text-gray-500">Knowledge base articles coming soon.</p>
        </div>
      )}
    </div>
  </section>
</LandingLayout>
