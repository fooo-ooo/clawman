---
import { getCollection } from 'astro:content';
import LandingLayout from '../../../layouts/LandingLayout.astro';

const lang = 'en';
const allDocs = await getCollection('docs');
const enDocs = allDocs.filter((doc) => doc.data.lang === 'en');

const categories = new Map<string, typeof enDocs>();
for (const doc of enDocs) {
  const cat = doc.data.category;
  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(doc);
}
for (const [, docs] of categories) {
  docs.sort((a, b) => a.data.order - b.data.order);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'OpenClaw Knowledge Base',
  description: 'Comprehensive documentation and guides for OpenClaw agent framework',
  url: 'https://clawman.fooo.ooo/en/docs/',
};
---

<LandingLayout
  title="OpenClaw Knowledge Base"
  description="Comprehensive documentation, guides, and tutorials for the OpenClaw agent framework. Learn to build, deploy, and manage AI agents."
  lang={lang}
  jsonLd={jsonLd}
>
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-6">
      <h1 class="text-3xl font-bold text-[--color-notion-text]">OpenClaw Knowledge Base</h1>
      <p class="mt-3 text-[--color-notion-secondary]">
        Everything you need to understand, deploy, and master OpenClaw — the open-source agent framework.
      </p>

      {categories.size > 0 ? (
        <div class="mt-12 space-y-10">
          {[...categories.entries()].map(([category, docs]) => (
            <div>
              <h2 class="text-xl font-bold text-[--color-notion-text]">{category}</h2>
              <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                {docs.map((doc) => (
                  <li>
                    <a
                      href={`/en/docs/${doc.id.replace('en/', '')}`}
                      class="block rounded-lg border border-[--color-notion-border] p-4 hover:bg-[--color-notion-light] transition-colors"
                    >
                      <h3 class="font-medium text-[--color-notion-text]">{doc.data.title}</h3>
                      <p class="mt-1 text-sm text-[--color-notion-secondary] line-clamp-2">{doc.data.description}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-lg border border-[--color-notion-border] p-12 text-center">
          <p class="text-[--color-notion-secondary]">Knowledge base articles coming soon.</p>
        </div>
      )}
    </div>
  </section>
</LandingLayout>
