---
import { getCollection } from 'astro:content';
import LandingLayout from '../../../layouts/LandingLayout.astro';

const lang = 'en';
const allDocs = await getCollection('docs');
const enDocs = allDocs.filter((doc) => doc.data.lang === 'en');

const categories = new Map<string, typeof enDocs>();
for (const doc of enDocs) {
  const cat = doc.data.category;
  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(doc);
}
for (const [, docs] of categories) {
  docs.sort((a, b) => a.data.order - b.data.order);
}

const categoryColors: Record<string, string> = {
  'Getting Started': 'bg-[--color-notion-teal]',
  'Core Concepts': 'bg-[--color-notion-blue]',
  'Architecture': 'bg-[--color-notion-purple]',
  'Guides': 'bg-[--color-notion-orange]',
  'Comparisons': 'bg-[--color-notion-red]',
  'Deployment': 'bg-[--color-notion-yellow]',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'OpenClaw Knowledge Base',
  description: 'Comprehensive documentation and guides for OpenClaw agent framework',
  url: 'https://clawman.fooo.ooo/en/docs/',
};
---

<LandingLayout
  title="OpenClaw Knowledge Base"
  description="Comprehensive documentation, guides, and tutorials for the OpenClaw agent framework. Learn to build, deploy, and manage AI agents."
  lang={lang}
  jsonLd={jsonLd}
>
  <section class="px-6 py-16 sm:py-24">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-4xl font-bold text-[--color-notion-text]">OpenClaw Knowledge Base</h1>
      <p class="mt-3 text-lg text-[--color-notion-secondary]">
        Everything you need to understand, deploy, and master OpenClaw.
      </p>

      {categories.size > 0 ? (
        <div class="mt-14 space-y-12">
          {[...categories.entries()].map(([category, docs]) => (
            <div>
              <h2 class="text-xl font-bold text-[--color-notion-text]">{category}</h2>
              <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {docs.map((doc) => (
                  <li>
                    <a
                      href={`/en/docs/${doc.id.replace('en/', '')}`}
                      class={`block rounded-2xl ${categoryColors[category] || 'bg-[--color-notion-light-gray]'} p-5 hover:opacity-80 transition-opacity`}
                    >
                      <h3 class="font-semibold text-[--color-notion-text]">{doc.data.title}</h3>
                      <p class="mt-1 text-sm text-[--color-notion-text]/60 line-clamp-2">{doc.data.description}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-2xl bg-[--color-notion-light-gray] p-12 text-center">
          <p class="text-[--color-notion-secondary]">Knowledge base articles coming soon.</p>
        </div>
      )}
    </div>
  </section>
</LandingLayout>
