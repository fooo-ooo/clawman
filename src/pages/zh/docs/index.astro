---
import { getCollection } from 'astro:content';
import LandingLayout from '../../../layouts/LandingLayout.astro';

const lang = 'zh';
const allDocs = await getCollection('docs');
const zhDocs = allDocs.filter((doc) => doc.data.lang === 'zh');

const categories = new Map<string, typeof zhDocs>();
for (const doc of zhDocs) {
  const cat = doc.data.category;
  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(doc);
}
for (const [, docs] of categories) {
  docs.sort((a, b) => a.data.order - b.data.order);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'OpenClaw 知识库',
  description: 'OpenClaw Agent 框架全面文档与指南',
  url: 'https://clawman.fooo.ooo/zh/docs/',
};
---

<LandingLayout
  title="OpenClaw 知识库"
  description="OpenClaw Agent 框架全面文档、指南与教程。学习构建、部署和管理 AI Agent。"
  lang={lang}
  jsonLd={jsonLd}
>
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-6">
      <h1 class="text-3xl font-bold text-[--color-notion-text]">OpenClaw 知识库</h1>
      <p class="mt-3 text-[--color-notion-secondary]">
        关于 OpenClaw 开源 Agent 框架，你需要了解的一切——从入门到精通。
      </p>

      {categories.size > 0 ? (
        <div class="mt-12 space-y-10">
          {[...categories.entries()].map(([category, docs]) => (
            <div>
              <h2 class="text-xl font-bold text-[--color-notion-text]">{category}</h2>
              <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                {docs.map((doc) => (
                  <li>
                    <a
                      href={`/zh/docs/${doc.id.replace('zh/', '')}`}
                      class="block rounded-lg border border-[--color-notion-border] p-4 hover:bg-[--color-notion-light] transition-colors"
                    >
                      <h3 class="font-medium text-[--color-notion-text]">{doc.data.title}</h3>
                      <p class="mt-1 text-sm text-[--color-notion-secondary] line-clamp-2">{doc.data.description}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-lg border border-[--color-notion-border] p-12 text-center">
          <p class="text-[--color-notion-secondary]">知识库文章即将上线。</p>
        </div>
      )}
    </div>
  </section>
</LandingLayout>
