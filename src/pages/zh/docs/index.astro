---
import { getCollection } from 'astro:content';
import LandingLayout from '../../../layouts/LandingLayout.astro';

const lang = 'zh';
const allDocs = await getCollection('docs');
const zhDocs = allDocs.filter((doc) => doc.data.lang === 'zh');

const categories = new Map<string, typeof zhDocs>();
for (const doc of zhDocs) {
  const cat = doc.data.category;
  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(doc);
}
for (const [, docs] of categories) {
  docs.sort((a, b) => a.data.order - b.data.order);
}

const categoryColors: Record<string, string> = {
  '入门': 'bg-[--color-notion-teal]',
  '核心概念': 'bg-[--color-notion-blue]',
  '架构': 'bg-[--color-notion-purple]',
  '实战指南': 'bg-[--color-notion-orange]',
  '对比分析': 'bg-[--color-notion-red]',
  '部署运维': 'bg-[--color-notion-yellow]',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'OpenClaw 知识库',
  description: 'OpenClaw Agent 框架全面文档与指南',
  url: 'https://clawman.fooo.ooo/zh/docs/',
};
---

<LandingLayout
  title="OpenClaw 知识库"
  description="OpenClaw Agent 框架全面文档、指南与教程。学习构建、部署和管理 AI Agent。"
  lang={lang}
  jsonLd={jsonLd}
>
  <section class="px-6 py-16 sm:py-24">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-4xl font-bold text-[--color-notion-text]">OpenClaw 知识库</h1>
      <p class="mt-3 text-lg text-[--color-notion-secondary]">
        关于 OpenClaw 开源 Agent 框架，你需要了解的一切。
      </p>

      {categories.size > 0 ? (
        <div class="mt-14 space-y-12">
          {[...categories.entries()].map(([category, docs]) => (
            <div>
              <h2 class="text-xl font-bold text-[--color-notion-text]">{category}</h2>
              <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {docs.map((doc) => (
                  <li>
                    <a
                      href={`/zh/docs/${doc.id.replace('zh/', '')}`}
                      class={`block rounded-2xl ${categoryColors[category] || 'bg-[--color-notion-light-gray]'} p-5 hover:opacity-80 transition-opacity`}
                    >
                      <h3 class="font-semibold text-[--color-notion-text]">{doc.data.title}</h3>
                      <p class="mt-1 text-sm text-[--color-notion-text]/60 line-clamp-2">{doc.data.description}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-2xl bg-[--color-notion-light-gray] p-12 text-center">
          <p class="text-[--color-notion-secondary]">知识库文章即将上线。</p>
        </div>
      )}
    </div>
  </section>
</LandingLayout>
